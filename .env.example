# Klaviyo Configuration
# Get your Public API Key (Company ID) from: Settings > API Keys
VITE_KLAVIYO_COMPANY_ID=your_public_api_key_here

# Get your List ID from: Audience > Lists & Segments > [Your List] > Settings
VITE_KLAVIYO_LIST_ID=your_list_id_here

# Firebase Configuration
# Get these from your Firebase Project Settings > General > Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
